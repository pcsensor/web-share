# 复制本文件为 .env，修改配置，然后在项目根目录执行：
#   cargo run --release
# 应用启动时会自动加载 .env（已存在的系统环境变量不会被覆盖）。

# 监听地址。公网裸奔可直接 0.0.0.0:8080；生产建议反代后只监听 127.0.0.1。
CHAT_BIND=0.0.0.0:8080

# 密封 TOTP 密钥用的 32 字节密钥（推荐 64 位 hex）。
# 生产务必固定设置；未设置时每次启动会生成临时密钥（重启后旧 TOTP 将无法解密）。
# 生成示例: openssl rand -hex 32
CHAT_SECRET_KEY=change-me-to-a-random-64-hex-chars-please-use-openssl

# 空库时自动创建首位管理员（仅当库中尚无 admin 时执行一次）。
# 管理员首次登录后须绑定 TOTP，才能使用聊天与后台。
# 注意：改 .env 里的密码不会自动改库中已有管理员密码！
CHAT_BOOTSTRAP_ADMIN_USER=admin
CHAT_BOOTSTRAP_ADMIN_PASSWORD=change-me-to-a-strong-password

# 紧急恢复（用完请改回 false 并重启）：
# CHAT_RESET_ADMIN_PASSWORD=true   # 将库中 bootstrap 用户密码重置为上面的 PASSWORD
# CHAT_RESET_ADMIN_TOTP=true       # 清除该管理员 TOTP，登录后重新绑定

# 是否开放用户自助注册
CHAT_REGISTRATION_OPEN=true

# TOTP 发行方名称（Authenticator 中显示；含空格必须加引号）
CHAT_TOTP_ISSUER="Chat Transfer"

# 受信任设备有效天数（登录勾选「信任此设备」后）
CHAT_DEVICE_TRUST_DAYS=60

# 邀请码有效时长（小时），默认 24
CHAT_INVITE_TTL_HOURS=24

# 数据目录（SQLite 库 + 上传文件）
# 结构：
#   data/chat.db
#   data/uploads/{uuid}.bin
CHAT_DATA_DIR=./data

# 单文件大小上限（MB）
CHAT_MAX_FILE_MB=100

# 文本消息最大字符数
CHAT_MAX_MSG_LEN=4000

# 在保留窗口内加载历史时的条数硬上限
CHAT_MAX_HISTORY=2000

# 数据保留时长（秒）：消息与上传文件统一过期，默认 3 小时
CHAT_RETENTION_SECS=10800

# 后台清理周期（秒）：删除过期 DB 记录与磁盘文件
CHAT_PURGE_INTERVAL_SECS=60

# 完整会话 Cookie 有效期（秒），默认 24 小时（可与消息保留解耦）
CHAT_SESSION_TTL_SECS=86400

# 等待 2FA / 绑定 TOTP 的短会话有效期（秒）
CHAT_PENDING_2FA_TTL_SECS=300

# 登录失败限流：窗口内最大尝试次数 / 窗口秒数
CHAT_LOGIN_MAX_ATTEMPTS=8
CHAT_LOGIN_WINDOW_SECS=300

# 生产环境在 HTTPS 下设为 true（Cookie 携带 Secure 标志）
CHAT_SECURE_COOKIE=false

# 日志级别
RUST_LOG=chat_transfer=info,tower_http=info
