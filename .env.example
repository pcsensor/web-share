# 复制本文件为 .env 后修改配置，然后在项目根目录执行：
#   cargo run --release
# 程序启动时会自动加载 .env（已存在的系统环境变量不会被覆盖）。
#
# 监听地址（公网服务器可直接 0.0.0.0:8080，生产建议反代后只监听 127.0.0.1）
CHAT_BIND=0.0.0.0:8080

# 管理员密码（明文会在启动时 bcrypt 哈希；也可直接填 bcrypt 哈希值，以 $2 开头）
CHAT_PASSWORD=change-me-to-a-strong-password

# 数据目录（SQLite 库 + 上传文件）
# 结构：
#   data/chat.db
#   data/uploads/{uuid}.bin
CHAT_DATA_DIR=./data

# 单文件最大体积（MB）
CHAT_MAX_FILE_MB=100

# 文本消息最大字符数
CHAT_MAX_MSG_LEN=4000

# 在保留窗口内加载历史时的条数硬上限
CHAT_MAX_HISTORY=2000

# 数据保留时长（秒）。消息与上传文件统一过期，默认 3 小时
CHAT_RETENTION_SECS=10800

# 后台清理周期（秒），删除过期 DB 记录与磁盘文件
CHAT_PURGE_INTERVAL_SECS=60

# 会话 Cookie 有效期（秒），默认与保留窗口一致（3 小时）
CHAT_SESSION_TTL_SECS=10800

# 登录失败限流：窗口内最多尝试次数 / 窗口秒数
CHAT_LOGIN_MAX_ATTEMPTS=8
CHAT_LOGIN_WINDOW_SECS=300

# 生产环境启用 HTTPS 后设为 true，Cookie 将带 Secure 标志
CHAT_SECURE_COOKIE=false

# 日志级别
RUST_LOG=chat_transfer=info,tower_http=info
